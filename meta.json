{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "biotinker:pointcloud-calibration",
  "visibility": "public",
  "url": "https://github.com/biotinker/pointcloud-calibration",
  "description": "calibrate depth camera frames on robot arms using pointcloud alignment",
  "markdown_link": "README.md",
  "models": [
    {
      "api": "rdk:service:generic",
      "model": "biotinker:pointcloud-calibration:depth-camera-on-arm",
      "short_description": "calibrate a depth camera mounted on an arm using pointcloud ICP alignment",
      "markdown_link": "README.md#configuration"
    }
  ],
  "entrypoint": "bin/pointcloud-calibration",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64"
    ]
  }
}
